# Copy to .env for local overrides. The demo works without editing this file.
PORT=4173
HOST=127.0.0.1
APP_ORIGIN=http://127.0.0.1:4173
DATA_DIR=./data
STORAGE_DIR=./storage/objects
SESSION_DAYS=7
MAX_UPLOAD_MB=12
COOKIE_SECURE=false
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=12
WRITE_RATE_LIMIT_MAX=80

# Demo OAuth placeholders. Real production wiring should replace the demo endpoints.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional OpenAI-compatible model provider. Leave as local-deterministic-agent
# for the offline deterministic harness used by the default demo.
MODEL_PROVIDER=local-deterministic-agent
MODEL_WIRE_API=chat-completions
MODEL_BASE_URL=
MODEL_NAME=
MODEL_API_KEY=
MODEL_TIMEOUT_MS=12000
MODEL_REASONING_EFFORT=
MODEL_DISABLE_RESPONSE_STORAGE=true

# Example for a Responses-compatible private provider. Keep MODEL_API_KEY out of git.
# MODEL_PROVIDER=fighting
# MODEL_WIRE_API=responses
# MODEL_BASE_URL=<provider-base-url>
# MODEL_NAME=gpt-5.5
# MODEL_REASONING_EFFORT=high
# MODEL_DISABLE_RESPONSE_STORAGE=true

